{# ===================== HERO / SIGN-UP BAND ===================== #}
<section class="vlog-hero" style="background-image:url('{{ '/assets/img/vlog-hero-connie.jpg' | url }}')">
  <div class="vlog-hero__overlay" aria-hidden="true"></div>
  <div class="container">
    <div class="vlog-hero__inner">
      <div class="vlog-hero__media">
        <img src="{{ '/assets/img/one-minute-mentoring-logo.png' | url }}" alt="One Minute Mentoring" />
      </div>
      <p class="vlog-hero__lead">You are invited to <b>sign up</b> for our <b>FREE weekly video message</b> that delivers encouragement, insight and actionable takeaways directly to your email.</p>
      {{ button("Sign me up!", "#vlog-signup", variant="accent") }}
    </div>
  </div>
</section>

{# ===================== YOUTUBE FEED (Connie Menser channel) ===================== #}
{% call section() %}
  <div class="vlog-feed">
    {% for video in videos %}
    <article class="vlog-card">
      <div class="vlog-card__media">
        <iframe
          src="https://www.youtube.com/embed/{{ video.id }}"
          title="{{ video.title }}"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          referrerpolicy="strict-origin-when-cross-origin"
          allowfullscreen></iframe>
      </div>
      <div class="vlog-card__body">
        <h3 class="vlog-card__title">
          <a href="https://www.youtube.com/watch?v={{ video.id }}" target="_blank" rel="noopener">{{ video.title }}</a>
        </h3>
        <p class="vlog-card__text">{{ video.text | safe }}</p>
      </div>
    </article>
    {% endfor %}
  </div>
  <div class="vlog-feed__actions">
    {{ button("Subscribe", channelUrl, variant="accent", attrs='target="_blank" rel="noopener"') }}
  </div>
{% endcall %}

{# ===================== SIGN-UP FOR ONE MINUTE MENTORING! ===================== #}
{% call section(tone="primary", id="vlog-signup") %}
  <div class="home-omm">
    <div class="home-omm__media">
      <img src="{{ '/assets/img/one-minute-mentoring-banner.png' | url }}" alt="One Minute Mentoring" loading="lazy" />
    </div>
    <div class="home-omm__body">
      <span class="section__eyebrow">Sign-up for our One Minute Mentoring Vlog</span>
      <h2>Sign-up for One Minute Mentoring!</h2>
      <p>You are invited to sign up for our FREE weekly video message that delivers encouragement, insight and actionable takeaways directly to your email.</p>

      <!-- TODO(forms): wire to Formspree endpoint -->
      <form class="home-signup" action="#" method="post" aria-label="One Minute Mentoring sign-up">
        <div class="home-signup__field">
          <label for="omm-first">First Name</label>
          <input type="text" id="omm-first" name="first_name" autocomplete="given-name" required />
        </div>
        <div class="home-signup__field">
          <label for="omm-last">Last Name</label>
          <input type="text" id="omm-last" name="last_name" autocomplete="family-name" required />
        </div>
        <div class="home-signup__field">
          <label for="omm-email">Email</label>
          <input type="email" id="omm-email" name="email" autocomplete="email" required />
        </div>
        <div class="home-signup__actions">
          <button class="btn btn--accent" type="submit">Sign Up</button>
        </div>
      </form>
    </div>
  </div>
{% endcall %}
