<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title %}{{ title }} — {% endif %}{{ site.name }}</title>
    {% if description %}<meta name="description" content="{{ description }}" />{% endif %}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="{{ '/assets/css/tokens.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/base.css' | url }}" />
    <link rel="stylesheet" href="{{ '/assets/css/components.css' | url }}" />
    {% if pageCss %}{% set cssSlug = page.fileSlug if page.fileSlug else 'index' %}<link rel="stylesheet" href="{{ ('/assets/css/pages/' + cssSlug + '.css') | url }}" />{% endif %}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    {% include "header.njk" %}
    <main id="main">
      {{ content | safe }}
    </main>
    {% include "footer.njk" %}
    <script src="{{ '/assets/js/nav.js' | url }}" defer></script>
  </body>
</html>
