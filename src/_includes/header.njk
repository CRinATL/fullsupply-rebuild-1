<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="{{ '/' | url }}">
      <img src="{{ site.logo | url }}" alt="{{ site.name }}" width="432" height="158" />
    </a>

    <button
      class="nav-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Toggle menu"
    >
      <span></span><span></span><span></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary">
      <ul class="primary-nav__list">
        {% for item in site.nav %}
          {%- set itemUrl = (item.url | url) if item.url[0] == '/' else item.url -%}
          <li class="primary-nav__item{% if item.children %} has-children{% endif %}">
            <a href="{{ itemUrl }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.title }}</a>
            {% if item.children %}
              <button class="submenu-toggle" aria-expanded="false" aria-label="Open {{ item.title }} submenu"></button>
              <ul class="sub-menu">
                {% for child in item.children %}
                  {%- set childUrl = (child.url | url) if child.url[0] == '/' else child.url -%}
                  <li><a href="{{ childUrl }}">{{ child.title }}</a></li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>

    <a class="btn btn--donate" href="{{ site.donate.url }}" target="_blank" rel="noopener">{{ site.donate.label }}</a>
  </div>
</header>
