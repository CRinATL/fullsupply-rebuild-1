  <figure class="nowa-testimonial">
    <div class="nowa-testimonial__media">
      <img src="{{ '/assets/img/nowa-nadia.jpg' | url }}" alt="" loading="lazy" />
    </div>
    <blockquote class="nowa-testimonial__quote">
      <p>&ldquo;It&rsquo;s not apparent how challenging and rewarding mentoring is until you are the one doing the mentoring.&rdquo;</p>
      <figcaption class="nowa-testimonial__cite">Nadia</figcaption>
    </blockquote>
  </figure>
{% endcall %}

