      <li>Invest in exemplary Mentor leaders who volunteer in their communities, churches and local non-profits, and also become successful business owners.</li>
      <li>Foster a network of strong, supportive women who inspire and lift each other.</li>
      <li>Transform the world by changing a life.</li>
    </ul>
  </div>

  <div class="nowa-tiers">
    <div class="nowa-tier nowa-tier--goal">
      <span class="nowa-tier__amount">5k Goal</span>
      <span class="nowa-tier__label">5k Fundraising Goal by October 18, 2026</span>
    </div>
    <div class="nowa-tier">
      <span class="nowa-tier__amount">$225</span>
      <span class="nowa-tier__label">World-Changer Level Sponsor</span>
    </div>
    <div class="nowa-tier">
      <span class="nowa-tier__amount">$150</span>
      <span class="nowa-tier__label">Multiplier Level Sponsor</span>
    </div>
    <div class="nowa-tier">
      <span class="nowa-tier__amount">$90</span>
      <span class="nowa-tier__label">Protege&rsquo; Level Sponsor</span>
    </div>
    <div class="nowa-tier">
      <span class="nowa-tier__amount">$30</span>
      <span class="nowa-tier__label">Apprentice Level Sponsor</span>
    </div>
    <div class="nowa-tier">
      <span class="nowa-tier__amount">15</span>
      <span class="nowa-tier__label">Mentee Level Sponsor</span>
    </div>
  </div>
{% endcall %}

{# ===================== BECOME A DONOR OR SPONSOR ===================== #}
{% call section(tone="alt", narrow=true) %}
  <div class="nowa-donor">
    <h2 class="nowa-heading">Become a Donor or Sponsor</h2>
    <p>Become an Event Sponsor or Donate for a worthy cause</p>
    <p>{{ button("Donate", paypalUrl, variant="donate", attrs='target="_blank" rel="noopener"') }}</p>

    <p class="nowa-donor__label">Sponsorship Levels &amp; Benefits Packet</p>
    <p>{{ button("Download", (sponsorPacketUrl | url), variant="outline", attrs='target="_blank" rel="noopener"') }}</p>

    <p class="nowa-donor__label">Got Questions?</p>
    <p>{{ button("Schedule A Call", scheduleUrl, attrs='target="_blank" rel="noopener"') }}</p>
  </div>
{% endcall %}

{# ===================== WILL YOU PRAYERFULLY BECOME A SPONSOR? ===================== #}
{% call section(tone="tan") %}
