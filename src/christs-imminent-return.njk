{# ===================== ONE MINUTE MENTORING FEED (static grid) ===================== #}
{% call section(tone="alt") %}
  <div class="omm-feed__head">
    <span class="omm-feed__channel">One Minute Mentoring</span>
  </div>
  <div class="omm-feed">
    {% for v in videos %}
    <article class="omm-video">
      <a class="omm-video__thumb" href="https://www.youtube.com/watch?v={{ v.id }}" target="_blank" rel="noopener" aria-label="Watch on YouTube: {{ v.title }}">
        <img src="https://i.ytimg.com/vi/{{ v.id }}/hqdefault.jpg" alt="" loading="lazy" />
        <span class="omm-video__play" aria-hidden="true"></span>
      </a>
      <div class="omm-video__body">
        <h3 class="omm-video__title">{{ v.title }}</h3>
        <p class="omm-video__desc">{{ v.desc }}</p>
      </div>
    </article>
    {% endfor %}
  </div>
  <div class="omm-feed__actions">
    {# "Load More..." paged the live YouTube feed in the original; static mirror has no further pages. #}
    {{ button("Load More...", "javascript:void(0);") }}
  </div>
{% endcall %}

{# ===================== BOTTOM SIGN-UP FORM ===================== #}
{% call section(tone="tan", id="omm-signup") %}
  <div class="omm-signup">
    <div class="omm-signup__media">
      <img src="{{ '/assets/img/one-minute-mentoring-banner.png' | url }}" alt="One Minute Mentoring" loading="lazy" />
    </div>
    <div class="omm-signup__body">
      <h2>Sign-up for One Minute Mentoring!</h2>
      <p>You are invited to sign up for our FREE weekly video message that delivers encouragement, insight and actionable takeaways directly to your email.</p>

      <!-- TODO(forms): wire to Formspree endpoint -->
      <form class="home-signup" action="#" method="post" aria-label="One Minute Mentoring sign-up">
        <div class="home-signup__field">
          <label for="omm-first">First Name</label>
          <input type="text" id="omm-first" name="first_name" autocomplete="given-name" required />
        </div>
        <div class="home-signup__field">
          <label for="omm-last">Last Name</label>
          <input type="text" id="omm-last" name="last_name" autocomplete="family-name" required />
        </div>
        <div class="home-signup__field">
          <label for="omm-email">Email</label>
          <input type="email" id="omm-email" name="email" autocomplete="email" required />
        </div>
        <div class="home-signup__actions">
          <button class="btn btn--accent" type="submit">Sign Up</button>
        </div>
      </form>
    </div>
  </div>
{% endcall %}
