{# ===================== TOP SIGN-UP BAND ===================== #}
{% call section(tone="", id="top") %}
  <div class="omm-band" style="background-image:linear-gradient(229deg, rgba(193,178,153,0.41) 47%, rgba(246,246,246,0.85) 61%), url('{{ '/assets/img/vlog-hero-connie.jpg' | url }}')">
