---
layout: base.njk
title: Home
description: Helping Faith-Driven Women to Grow in Faith and Lead with Confidence.
pageCss: true
---
{% from "components/macros.njk" import button, section, sectionHead, hero, ctaBand, card, cardGrid %}

{% set scheduleUrl = "https://sfkakxvwfuajznbsmu.10to8.com/" %}

{# Inline SVG icons for the three pillars (praying hands / anchor / users),
   matching the original Font Awesome icons without the dependency. #}
{% set icoFaith %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21V7c0-1.6.7-3.2 1.9-4.3l.4-.3c.5-.5 1.4-.3 1.6.4.4 1 .6 2.2.6 3.3 0 .9.5 1.7 1.3 2.1l.9.5c.8.5 1.3 1.4 1.3 2.3V16c0 1.7-1 3.2-2.6 3.8L12 21Z"/><path d="M12 21V7c0-1.6-.7-3.2-1.9-4.3l-.4-.3c-.5-.5-1.4-.3-1.6.4-.4 1-.6 2.2-.6 3.3 0 .9-.5 1.7-1.3 2.1l-.9.5C4.5 9.7 4 10.6 4 11.5V16c0 1.7 1 3.2 2.6 3.8L12 21Z"/></svg>{% endset %}
{% set icoMentor %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><line x1="12" y1="22" x2="12" y2="8"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/></svg>{% endset %}
{% set icoLeaders %}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>{% endset %}

{# ===================== HERO ===================== #}
{% call hero(
  "Training Leaders.<span class='hero__accent'>Transforming Lives.</span>",
  subtitle="Helping Faith-Driven Women to Grow in Faith and Lead Others with Confidence.",
  bgImage=("/assets/img/home-hero-connie.jpg" | url),
  overlay="light"
) %}
  {{ button("Schedule a Call", scheduleUrl, size="lg", attrs='target="_blank" rel="noopener"') }}
{% endcall %}

{# ===================== THREE PILLARS (icon row) ===================== #}
{% call section(tone="alt", size="tight") %}
  {% call cardGrid(cols="3") %}
    {{ card("Strengthen Your Faith", icon=icoFaith, feature=true) }}
    {{ card("Confidently Mentor Women", icon=icoMentor, feature=true) }}
    {{ card("Shape Future Leaders", icon=icoLeaders, feature=true) }}
  {% endcall %}
{% endcall %}

{# ===================== DO YOU OFTEN SAY… ===================== #}
{% call section() %}
  <h2 class="home-says__lead">Do you <span class="is-accent">often</span> say&hellip;</h2>
  <p class="section__lead">Do you find yourself saying&hellip;</p>
  <ul class="home-says">
    <li>I would like training so I will know how to mentor effectively.</li>
    <li>I would like to be confident and build a solid foundation in my biblical knowledge.</li>
    <li>I feel a strong desire to help mentor other women in their spiritual growth.</li>
  </ul>
  <p>At Full Supply, we understand many Christian women have apprehensions about themselves and mentoring. But we believe you have the capacity to make a valuable contribution in a woman&rsquo;s faith journey.</p>
  <p>That&rsquo;s why we are committed to providing you the training, mentoring and resources you need to become a more confident mentor who shapes future leaders for kingdom impact.</p>
  <p>We want to help bring out the mentor leader in you.</p>
  <p>{{ button("Schedule a Call", scheduleUrl, variant="accent", attrs='target="_blank" rel="noopener"') }}</p>
{% endcall %}

{# ===================== AT FULL SUPPLY, YOU CAN EXPECT… ===================== #}
{% call section(tone="tan") %}
  {{ sectionHead("At Full Supply, you can expect…", center=true) }}
  {% call cardGrid(cols="3") %}
    {{ card("Biblical Foundation", text="The Bible is our guide and we integrate Scripture throughout all aspects of mentoring. Our mentors are confident believers who know God&rsquo;s Word.", feature=true) }}
    {{ card("Practical Skills", text="Lead from your best self. Our unique framework includes Mentor Mastery Training and a 3-phase mentoring model that gives you the tools you need to mentor with confidence and ease.", feature=true) }}
    {{ card("Peer Mentoring", text="Be surrounded by Christ-centered peer mentors. Join an inspiring team of mentor-leaders who meet monthly to sharpen one another and lead by a higher standard to guide mentees well.", feature=true) }}
  {% endcall %}
{% endcall %}

{# ===================== ONE MINUTE MENTORING SIGN-UP BAND ===================== #}
{% call section(tone="primary", id="one-minute-mentoring") %}
  <div class="home-omm">
    <div class="home-omm__media">
      <img src="{{ '/assets/img/one-minute-mentoring-logo.png' | url }}" alt="One Minute Mentoring" loading="lazy" />
    </div>
    <div class="home-omm__body">
      <span class="section__eyebrow">Sign-up for our One Minute Mentoring Vlog</span>
      <h2>Sign-up for One Minute Mentoring!</h2>
      <p>You are invited to sign up for our FREE weekly video message that delivers encouragement, insight and actionable takeaways directly to your email.</p>

      <!-- TODO(forms): wire to Formspree endpoint -->
      <form class="home-signup" action="#" method="post" aria-label="One Minute Mentoring sign-up">
        <div class="home-signup__field">
          <label for="omm-first">First Name</label>
          <input type="text" id="omm-first" name="first_name" autocomplete="given-name" required />
        </div>
        <div class="home-signup__field">
          <label for="omm-last">Last Name</label>
          <input type="text" id="omm-last" name="last_name" autocomplete="family-name" required />
        </div>
        <div class="home-signup__field">
          <label for="omm-email">Email</label>
          <input type="email" id="omm-email" name="email" autocomplete="email" required />
        </div>
        <div class="home-signup__actions">
          <button class="btn btn--accent" type="submit">Sign Up</button>
        </div>
      </form>
    </div>
  </div>
{% endcall %}

{# ===================== THE PATH TO MENTORING ===================== #}
{% call section() %}
  {{ sectionHead("The Path to Mentoring at Full Supply", center=true) }}
  <div class="home-path">
    <div class="home-path__media">
      <img src="{{ '/assets/img/path-to-mentoring.jpg' | url }}" alt="A mentor and mentee in conversation" loading="lazy" />
    </div>
    <div class="home-path__steps">
      {% call cardGrid(cols="3") %}
        {{ card("Grow", text="We train you on how to help your mentee establish a strong Biblical foundation and identifying how Jesus is working in their life.", icon="1", feature=true) }}
        {{ card("Build", text="We will help you cement your mentee&rsquo;s foundation by building their relationship with Jesus and begin to explore ways to put their faith into action within their world.", icon="2", feature=true) }}
        {{ card("Lead", text="We will give you the tools and resources you need to lead your mentees to become equipped and confident in their faith and share their faith with others.", icon="3", feature=true) }}
      {% endcall %}
    </div>
  </div>
{% endcall %}

{# ===================== TESTIMONIALS ===================== #}
{% call section(tone="alt") %}
  {{ sectionHead("What women are saying", eyebrow="Testimonials", center=true) }}
  {% call cardGrid(cols="3") %}
    {{ card(
      "Jerrica",
      text="&ldquo;Though there is a curriculum to follow, I felt like Full Supply met me where I was and gave me a framework to meet the needs of women looking for a mentor.&rdquo;",
