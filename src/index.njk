    {{ card(
      "Zahra",
      text="&ldquo;Full Supply is a place where you can be and become fully you. They help you become who you are destined to be.&rdquo;",
      image=("/assets/img/testimonial-zahra-bailey.jpg" | url)
    ) }}
  {% endcall %}
{% endcall %}

